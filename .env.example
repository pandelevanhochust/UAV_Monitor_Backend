##############################################################################
# UAV Drone Detection System — Environment Variables Template
# Copy this file to .env and fill in production-grade secrets.
# NEVER commit the .env file to version control.
##############################################################################

# ── PostgreSQL (UserService, DeviceService) ──────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=uav_system
POSTGRES_USER=uav_admin
POSTGRES_PASSWORD=secure_dev_postgres_password_123
POSTGRES_DB_USER=uav_user_db
POSTGRES_DB_DEVICE=uav_device_db
POSTGRES_DB=postgres

# ── ClickHouse (IngestionService writes, LogService reads) ───────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=uav_logs
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=secure_dev_clickhouse_password_000

# ── Redis (IngestionService, DeviceService, AlertService) ────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_dev_redis_password_456

# ── RabbitMQ (IngestionService publishes, AlertService consumes) ─────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=uav_broker_admin
RABBITMQ_DEFAULT_PASS=secure_dev_rabbitmq_password_789
RABBITMQ_VHOST=/

# ── JWT Token Signing Authority (UserService) ────────────────────────────────
JWT_SECRET=super_secret_32_character_signing_key_boundary_123!
JWT_ISSUER=uav-detection-system
JWT_AUDIENCE=uav-supervisors
JWT_EXPIRES_SECONDS=86400
