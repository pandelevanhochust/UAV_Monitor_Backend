##############################################################################
# UAV Drone Detection System — Environment Variables Template
# Copy this file to .env and fill in production-grade secrets.
# NEVER commit the .env file to version control.
##############################################################################

# ── PostgreSQL Cluster (Database-per-Service Architecture) ───────────────────
# Each microservice connects to its own isolated database.
# The postgres container creates both DBs via infra/postgres/init/ scripts.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=uav_admin
POSTGRES_PASSWORD=<your_postgres_password>

# UserService — owns uav_user_db exclusively
POSTGRES_DB_USER=uav_user_db

# DeviceService — owns uav_device_db exclusively
POSTGRES_DB_DEVICE=uav_device_db

# ── ClickHouse (IngestionService writes, LogService reads) ───────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=uav_logs
CLICKHOUSE_USER=uav_analytics
CLICKHOUSE_PASSWORD=<your_clickhouse_password>

# ── Redis (IngestionService, DeviceService, AlertService) ────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<your_redis_password>

# ── RabbitMQ (IngestionService publishes, AlertService consumes) ─────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=uav_broker
RABBITMQ_DEFAULT_PASS=<your_rabbitmq_password>
RABBITMQ_VHOST=/

# ── JWT Token Signing Authority (UserService) ────────────────────────────────
JWT_SECRET=<your_32_character_minimum_signing_key>
JWT_ISSUER=uav-detection-system
JWT_AUDIENCE=uav-supervisors
JWT_EXPIRES_SECONDS=86400
